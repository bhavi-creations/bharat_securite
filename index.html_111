<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Bharat Security Services</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

  <style>
    :root {
      --gold:        #C9A84C;
      --gold-light:  #F0D080;
      --gold-dark:   #9A7A2A;
      --black:       #0A0A0A;
      --black-mid:   #111111;
      --black-soft:  #1A1A1A;
      --green:       #4CAF50;
      --green-dark:  #2E7D32;
      --text-muted:  #888888;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--black);
      color: #ddd;
      font-family: 'Lato', sans-serif;
      font-weight: 300;
      overflow-x: hidden;
    }

    /* ── NAVBAR ── */
    .navbar {
      background: rgba(0,0,0,0.92) !important;
      border-bottom: 1px solid var(--gold-dark);
      backdrop-filter: blur(12px);
      padding: 14px 0;
      position: fixed; top: 0; width: 100%; z-index: 1000;
      transition: background .3s;
    }
    .navbar-brand {
      font-family: 'Cinzel', serif;
      font-weight: 900;
      font-size: 1.3rem;
      letter-spacing: 3px;
      color: var(--gold) !important;
    }
    .navbar-brand span { color: #fff; }
    .nav-link {
      font-family: 'Lato', sans-serif;
      font-weight: 700;
      font-size: .75rem;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: #bbb !important;
      padding: 6px 18px !important;
      transition: color .25s;
    }
    .nav-link:hover, .nav-link.active { color: var(--gold) !important; }
    .navbar-toggler { border-color: var(--gold-dark); }
    .navbar-toggler-icon {
      filter: invert(1) sepia(1) saturate(5) hue-rotate(2deg);
    }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      background:
        radial-gradient(ellipse at 50% 0%, rgba(201,168,76,.13) 0%, transparent 65%),
        linear-gradient(175deg, #0d0d0d 0%, #0A0A0A 100%);
      display: flex; align-items: center; justify-content: center;
      text-align: center;
      position: relative;
      overflow: hidden;
      padding-top: 80px;
    }
    .hero::before {
      content: '';
      position: absolute; inset: 0;
      background: repeating-linear-gradient(
        0deg, transparent, transparent 79px,
        rgba(201,168,76,.04) 80px
      ),
      repeating-linear-gradient(
        90deg, transparent, transparent 79px,
        rgba(201,168,76,.04) 80px
      );
      pointer-events: none;
    }
    .hero-badge {
      display: inline-block;
      border: 1px solid var(--gold-dark);
      color: var(--gold);
      font-family: 'Lato', sans-serif;
      font-weight: 700;
      font-size: .65rem;
      letter-spacing: 4px;
      text-transform: uppercase;
      padding: 7px 22px;
      border-radius: 2px;
      margin-bottom: 28px;
      animation: fadeUp .8s ease both;
    }
    .hero h1 {
      font-family: 'Cinzel', serif;
      font-weight: 900;
      font-size: clamp(2.8rem, 8vw, 6rem);
      line-height: 1;
      letter-spacing: 6px;
      text-transform: uppercase;
      color: #fff;
      animation: fadeUp .9s .1s ease both;
    }
    .hero h1 .gold { color: var(--gold); }
    .hero-sub {
      font-family: 'Lato', sans-serif;
      font-weight: 300;
      font-size: 1rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-top: 14px;
      animation: fadeUp 1s .2s ease both;
    }
    .hero-divider {
      width: 60px; height: 2px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
      margin: 30px auto;
      animation: fadeUp 1s .3s ease both;
    }
    .hero p {
      max-width: 560px; margin: 0 auto 40px;
      color: #999; font-size: 1rem; line-height: 1.8;
      animation: fadeUp 1s .4s ease both;
    }
    .hero-cta {
      display: inline-flex; gap: 16px; flex-wrap: wrap; justify-content: center;
      animation: fadeUp 1s .5s ease both;
    }
    .btn-gold {
      background: linear-gradient(135deg, var(--gold-dark), var(--gold), var(--gold-light));
      color: #000;
      font-family: 'Lato', sans-serif;
      font-weight: 700;
      font-size: .72rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      padding: 14px 36px;
      border: none;
      border-radius: 2px;
      text-decoration: none;
      transition: transform .25s, box-shadow .25s;
      box-shadow: 0 6px 28px rgba(201,168,76,.3);
    }
    .btn-gold:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 40px rgba(201,168,76,.45);
      color: #000;
    }
    .btn-outline-gold {
      background: transparent;
      color: var(--gold);
      font-family: 'Lato', sans-serif;
      font-weight: 700;
      font-size: .72rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      padding: 13px 36px;
      border: 1px solid var(--gold-dark);
      border-radius: 2px;
      text-decoration: none;
      transition: all .25s;
    }
    .btn-outline-gold:hover {
      background: rgba(201,168,76,.08);
      border-color: var(--gold);
      color: var(--gold-light);
    }
    .hero-scroll {
      position: absolute; bottom: 36px; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 6px;
      color: var(--text-muted); font-size: .65rem; letter-spacing: 3px;
      text-transform: uppercase; animation: bounce 2s infinite;
    }
    .hero-scroll i { font-size: .9rem; color: var(--gold); }

    /* ── STATS BAR ── */
    .stats-bar {
      background: var(--black-soft);
      border-top: 1px solid rgba(201,168,76,.2);
      border-bottom: 1px solid rgba(201,168,76,.2);
      padding: 30px 0;
    }
    .stat-item { text-align: center; padding: 10px 0; }
    .stat-num {
      font-family: 'Cinzel', serif;
      font-size: 2.2rem;
      font-weight: 700;
      color: var(--gold);
      display: block;
      line-height: 1;
    }
    .stat-label {
      font-size: .68rem;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-top: 6px;
      display: block;
    }

    /* ── SECTION COMMON ── */
    section { padding: 90px 0; }
    .section-tag {
      font-size: .65rem; letter-spacing: 4px; text-transform: uppercase;
      color: var(--gold); font-weight: 700; margin-bottom: 12px;
    }
    .section-title {
      font-family: 'Cinzel', serif;
      font-weight: 700;
      font-size: clamp(1.7rem, 4vw, 2.6rem);
      color: #fff;
      line-height: 1.15;
      margin-bottom: 16px;
    }
    .section-line {
      width: 50px; height: 2px;
      background: linear-gradient(90deg, var(--gold), transparent);
      margin-bottom: 20px;
    }
    .section-desc {
      color: #888; font-size: .97rem; line-height: 1.8; max-width: 520px;
    }

    /* ── SERVICES ── */
    #services { background: var(--black-mid); }
    .service-card {
      background: var(--black-soft);
      border: 1px solid rgba(201,168,76,.15);
      border-radius: 4px;
      padding: 36px 30px;
      height: 100%;
      position: relative;
      overflow: hidden;
      transition: border-color .3s, transform .3s, box-shadow .3s;
    }
    .service-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
      opacity: 0; transition: opacity .3s;
    }
    .service-card:hover {
      border-color: rgba(201,168,76,.4);
      transform: translateY(-4px);
      box-shadow: 0 16px 48px rgba(0,0,0,.5);
    }
    .service-card:hover::before { opacity: 1; }
    .service-icon {
      width: 52px; height: 52px;
      background: rgba(201,168,76,.1);
      border: 1px solid var(--gold-dark);
      border-radius: 4px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem;
      color: var(--gold);
      margin-bottom: 22px;
      transition: background .3s;
    }
    .service-card:hover .service-icon { background: rgba(201,168,76,.18); }
    .service-card h5 {
      font-family: 'Cinzel', serif;
      font-size: .95rem;
      font-weight: 700;
      letter-spacing: 1.5px;
      color: #fff;
      margin-bottom: 12px;
      text-transform: uppercase;
    }
    .service-card p { color: #888; font-size: .9rem; line-height: 1.7; }

    /* ── WHY US ── */
    #why { background: var(--black); }
    .why-img-wrap {
      position: relative;
      display: inline-block;
    }
    .why-img-wrap img {
      width: 100%; border-radius: 4px;
      filter: grayscale(30%) contrast(1.05);
    }
    .why-img-badge {
      position: absolute; bottom: -18px; right: -18px;
      background: linear-gradient(135deg, var(--gold-dark), var(--gold));
      color: #000;
      font-family: 'Cinzel', serif;
      font-weight: 700;
      font-size: .85rem;
      letter-spacing: 1px;
      padding: 20px 24px;
      border-radius: 4px;
      text-align: center;
      line-height: 1.3;
      box-shadow: 0 8px 28px rgba(0,0,0,.5);
    }
    .why-img-badge strong { font-size: 2rem; display: block; }
    .check-item {
      display: flex; gap: 16px; align-items: flex-start;
      margin-bottom: 22px;
    }
    .check-icon {
      width: 32px; height: 32px; flex-shrink: 0;
      background: rgba(76,175,80,.12);
      border: 1px solid var(--green-dark);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: var(--green);
      font-size: .8rem;
      margin-top: 2px;
    }
    .check-item h6 {
      font-family: 'Cinzel', serif;
      font-size: .82rem; letter-spacing: 1px;
      color: #fff; margin-bottom: 4px; text-transform: uppercase;
    }
    .check-item p { color: #888; font-size: .88rem; line-height: 1.6; margin: 0; }

    /* ── TESTIMONIALS ── */
    #testimonials { background: var(--black-mid); }
    .testi-card {
      background: var(--black-soft);
      border: 1px solid rgba(201,168,76,.12);
      border-radius: 4px;
      padding: 34px 30px;
      height: 100%;
      position: relative;
    }
    .testi-card .quote-icon {
      font-size: 2.5rem;
      color: rgba(201,168,76,.2);
      line-height: 1;
      margin-bottom: 18px;
      font-family: Georgia, serif;
    }
    .testi-card p {
      color: #999; font-size: .93rem; line-height: 1.75;
      font-style: italic; margin-bottom: 24px;
    }
    .testi-author {
      display: flex; align-items: center; gap: 14px;
    }
    .testi-avatar {
      width: 44px; height: 44px;
      background: linear-gradient(135deg, var(--gold-dark), var(--gold));
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Cinzel', serif;
      font-weight: 700;
      color: #000;
      font-size: .95rem;
    }
    .testi-author strong {
      display: block; font-family: 'Lato'; font-weight: 700;
      font-size: .85rem; color: #ddd; margin-bottom: 2px;
    }
    .testi-author span { font-size: .75rem; color: var(--text-muted); letter-spacing: 1px; }
    .stars { color: var(--gold); font-size: .75rem; margin-bottom: 4px; }

    /* ── CONTACT ── */
    #contact { background: var(--black); }
    .contact-box {
      background: var(--black-soft);
      border: 1px solid rgba(201,168,76,.18);
      border-radius: 4px;
      padding: 48px 44px;
    }
    .form-label {
      font-size: .7rem; letter-spacing: 2.5px;
      text-transform: uppercase; color: var(--text-muted);
      font-weight: 700; margin-bottom: 8px;
    }
    .form-control, .form-select {
      background: rgba(255,255,255,.04) !important;
      border: 1px solid rgba(201,168,76,.2) !important;
      color: #ddd !important;
      border-radius: 2px;
      padding: 12px 16px;
      font-size: .9rem;
      transition: border-color .25s, box-shadow .25s;
    }
    .form-control:focus, .form-select:focus {
      border-color: var(--gold) !important;
      box-shadow: 0 0 0 3px rgba(201,168,76,.12) !important;
      outline: none;
    }
    .form-control::placeholder { color: #555 !important; }
    .form-select option { background: #1a1a1a; }
    textarea.form-control { resize: none; }
    .contact-info-item {
      display: flex; align-items: flex-start; gap: 16px;
      margin-bottom: 28px;
    }
    .contact-info-icon {
      width: 40px; height: 40px; flex-shrink: 0;
      background: rgba(201,168,76,.08);
      border: 1px solid var(--gold-dark);
      border-radius: 4px;
      display: flex; align-items: center; justify-content: center;
      color: var(--gold); font-size: .9rem;
    }
    .contact-info-item strong {
      display: block; font-size: .7rem; letter-spacing: 2px;
      text-transform: uppercase; color: var(--text-muted); margin-bottom: 4px;
    }
    .contact-info-item span { color: #ccc; font-size: .93rem; }

    /* ── FOOTER ── */
    footer {
      background: var(--black-soft);
      border-top: 1px solid rgba(201,168,76,.15);
      padding: 40px 0 24px;
    }
    .footer-brand {
      font-family: 'Cinzel', serif;
      font-weight: 900;
      font-size: 1.1rem;
      letter-spacing: 3px;
      color: var(--gold);
    }
    .footer-brand span { color: #fff; }
    .footer-links a {
      color: #666; font-size: .8rem; letter-spacing: 1.5px;
      text-transform: uppercase; text-decoration: none;
      margin: 0 12px;
      transition: color .25s;
    }
    .footer-links a:hover { color: var(--gold); }
    .footer-copy {
      color: #444; font-size: .75rem; text-align: center;
      margin-top: 24px; letter-spacing: 1px;
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(28px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes bounce {
      0%, 100% { transform: translateX(-50%) translateY(0); }
      50%       { transform: translateX(-50%) translateY(8px); }
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .contact-box { padding: 30px 22px; }
      .why-img-badge { right: 0; bottom: -12px; }
    }
  </style>
</head>

<body>

<!-- ══════ NAVBAR ══════ -->
<nav class="navbar navbar-expand-lg">
  <div class="container">
    <a class="navbar-brand" href="#home">BHARAT <span>SECURITY</span></a>
    <!-- <a class="navbar-brand" href="#home"><img src="./assets/img/logo.png" alt="" style="width: 80px;"></a> -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse justify-content-end" id="navMenu">
      <ul class="navbar-nav align-items-lg-center gap-1">
        <li class="nav-item"><a class="nav-link active" href="#home">Home</a></li>
        <li class="nav-item"><a class="nav-link" href="#services">Services</a></li>
        <li class="nav-item"><a class="nav-link" href="#why">About</a></li>
        <li class="nav-item"><a class="nav-link" href="#testimonials">Clients</a></li>
        <li class="nav-item ms-lg-2">
          <a class="btn-gold" href="#contact" style="padding:10px 26px;font-size:.68rem;letter-spacing:2.5px;border-radius:2px;">
            Get a Quote
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<!-- ══════ HERO ══════ -->
<section class="hero" id="home">
  <div class="container text-center">
    <div class="hero-badge">Est. 2010 &nbsp;·&nbsp; Licensed &amp; Certified</div>
    <h1>BHARAT<br><span class="gold">SECURITY</span><br>SERVICES</h1>
    <p class="hero-sub">Protecting What Matters Most</p>
    <div class="hero-divider"></div>
    <p>India's trusted security partner — delivering professional guard services, surveillance, and risk management solutions for businesses, institutions, and events across the nation.</p>
    <div class="hero-cta">
      <a href="#services" class="btn-gold">Explore Services</a>
      <a href="#contact" class="btn-outline-gold">Contact Us</a>
    </div>
  </div>
  <div class="hero-scroll">
    <i class="fas fa-chevron-down"></i>
    <span>Scroll</span>
  </div>
</section>

<!-- ══════ STATS BAR ══════ -->
<div class="stats-bar">
  <div class="container">
    <div class="row g-0 text-center">
      <div class="col-6 col-md-3">
        <div class="stat-item">
          <span class="stat-num">15+</span>
          <span class="stat-label">Years Experience</span>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-item">
          <span class="stat-num">2,400+</span>
          <span class="stat-label">Guards Deployed</span>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-item">
          <span class="stat-num">500+</span>
          <span class="stat-label">Client Sites</span>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-item">
          <span class="stat-num">24/7</span>
          <span class="stat-label">Round-the-Clock</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ══════ SERVICES ══════ -->
<section id="services">
  <div class="container">
    <div class="text-center mb-5">
      <p class="section-tag">What We Offer</p>
      <h2 class="section-title">Comprehensive Security Solutions</h2>
      <div class="section-line mx-auto" style="background:linear-gradient(90deg,transparent,var(--gold),transparent);"></div>
      <p class="section-desc mx-auto">From on-site guard deployment to advanced electronic surveillance, we offer end-to-end protection services tailored to your unique needs.</p>
    </div>
    <div class="row g-4">
      <div class="col-md-6 col-lg-4">
        <div class="service-card">
          <div class="service-icon"><i class="fas fa-shield-halved"></i></div>
          <h5>Armed & Unarmed Guards</h5>
          <p>Highly trained, background-verified security personnel for commercial, residential, and industrial premises — available round the clock.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4">
        <div class="service-card">
          <div class="service-icon"><i class="fas fa-camera"></i></div>
          <h5>CCTV Surveillance</h5>
          <p>State-of-the-art camera installation, live monitoring, and remote surveillance systems designed to deter threats before they escalate.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4">
        <div class="service-card">
          <div class="service-icon"><i class="fas fa-calendar-check"></i></div>
          <h5>Event Security</h5>
          <p>End-to-end event management security — crowd control, VIP protection, access control, and emergency response coordination.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4">
        <div class="service-card">
          <div class="service-icon"><i class="fas fa-car"></i></div>
          <h5>Mobile Patrol Services</h5>
          <p>Regular and randomised patrol routes across your campus or facility, ensuring comprehensive coverage and rapid response.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4">
        <div class="service-card">
          <div class="service-icon"><i class="fas fa-user-tie"></i></div>
          <h5>Executive Protection</h5>
          <p>Discreet, professional close-protection officers for corporate executives, dignitaries, and high-net-worth individuals.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4">
        <div class="service-card">
          <div class="service-icon"><i class="fas fa-building"></i></div>
          <h5>Corporate Security</h5>
          <p>Integrated security programs for offices, IT parks, and commercial complexes — access management, visitor control, and emergency planning.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════ WHY US ══════ -->
<section id="why">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-5 order-lg-2">
        <p class="section-tag">Why Choose Us</p>
        <h2 class="section-title">Trusted Protection,<br>Proven Integrity</h2>
        <div class="section-line"></div>
        <p class="section-desc mb-4">Bharat Security Services combines military-grade training with local intelligence to deliver security solutions that truly work in India's diverse environments.</p>

        <div class="check-item">
          <div class="check-icon"><i class="fas fa-check"></i></div>
          <div>
            <h6>Government Licensed</h6>
            <p>Fully licensed under the Private Security Agencies Regulation Act (PSARA) and compliant with all statutory requirements.</p>
          </div>
        </div>
        <div class="check-item">
          <div class="check-icon"><i class="fas fa-check"></i></div>
          <div>
            <h6>Ex-Defence Personnel</h6>
            <p>Our guard force includes veterans from the Indian Army, Police, and Paramilitary forces — discipline and experience built-in.</p>
          </div>
        </div>
        <div class="check-item">
          <div class="check-icon"><i class="fas fa-check"></i></div>
          <div>
            <h6>Rapid Deployment</h6>
            <p>On-ground mobilisation within 24 hours across Andhra Pradesh, Telangana, and neighbouring states.</p>
          </div>
        </div>
        <div class="check-item">
          <div class="check-icon"><i class="fas fa-check"></i></div>
          <div>
            <h6>Technology-Enabled</h6>
            <p>Guards equipped with GPS tracking, real-time reporting apps, and panic alert systems for maximum accountability.</p>
          </div>
        </div>
      </div>

      <div class="col-lg-7 order-lg-1">
        <div class="why-img-wrap" style="padding-bottom:22px;padding-right:22px;">
          <!-- Placeholder illustrated graphic using SVG -->
